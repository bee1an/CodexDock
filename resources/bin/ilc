#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

for candidate in \
  "$SCRIPT_DIR/../../MacOS/Ilovecodex" \
  "$SCRIPT_DIR/../../ilovecodex" \
  "$SCRIPT_DIR/../../Ilovecodex" \
  "$SCRIPT_DIR/../ilovecodex" \
  "$SCRIPT_DIR/../Ilovecodex"
do
  if [ -x "$candidate" ]; then
    exec "$candidate" --cli "$@"
  fi
done

echo "Unable to locate the bundled Ilovecodex executable" >&2
exit 3
